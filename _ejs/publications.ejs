```{=html}
<%
var authorProfileSlugs = {
  "alice plebe": "plebe-alice",
  "baroni francesco": "baroni-francesco",
  "ciuffoletti sabrina": "ciuffoletti-sabrina",
  "davide de martini": "de-martini-davide",
  "de martini davide": "de-martini-davide",
  "defrancesco gioele": "defrancesco-gioele",
  "faccini filippo": "filippo-faccini",
  "filippo faccini": "filippo-faccini",
  "francesco baroni": "baroni-francesco",
  "gastone pietro rosati papini": "rosati-papini-gastone-pietro",
  "gioele defrancesco": "defrancesco-gioele",
  "giovanni maria francesco la scala": "la-scala-giovanni-maria-francesco",
  "giovanni scialla": "scialla-giovanni",
  "la scala giovanni maria francesco": "la-scala-giovanni-maria-francesco",
  "mattia piazza": "piazza-mattia",
  "mojtaba sharifzadeh": "Sharifzadeh-Mojtaba",
  "piazza mattia": "piazza-mattia",
  "plebe alice": "plebe-alice",
  "rosati papini gastone pietro": "rosati-papini-gastone-pietro",
  "sabrina ciuffoletti": "ciuffoletti-sabrina",
  "scialla giovanni": "scialla-giovanni",
  "sebastiano taddei": "taddei-sebastiano",
  "sharifzadeh mojtaba": "Sharifzadeh-Mojtaba",
  "taddei sebastiano": "taddei-sebastiano",
};
var profilePathForAuthor = function(author) {
  var key = author.toLowerCase().replace(/\s+/g, " ").trim();
  var slug = authorProfileSlugs[key];
  return slug ? "/people/" + slug + "/" : null;
};
%>
<div class="list quarto-listing-default">
    <% for (const item of items) { %>
    
    <div class="quarto-post image-left" <%= metadataAttrs(item) %> >
        <div class="thumbnail">
            <% if (item.image) { %>
            <a href="<%- item.path %>">
                <p>
                    <% 
                    // Construct full image path if it's relative
                    const imagePath = item.image.startsWith('/') || item.image.startsWith('http') 
                        ? item.image 
                        : item.path.substring(0, item.path.lastIndexOf('/') + 1) + item.image;
                    %>
                    <img alt="<%= item.title %>" src="<%= imagePath %>" class="thumbnail-image">
                </p>
            </a>
            <% } else if (item.video) { %>
            <a href="<%- item.path %>">
                <p>
                    <img alt="<%= item.title %>" src="https://img.youtube.com/vi/<%= item.video %>/0.jpg" class="thumbnail-image">
                </p>
            </a>
            <% } else if (item.logo) { %>
            <a href="<%- item.path %>">
                <p>
                    <img alt="<%= item.logo %> logo" src="/_images/_third_parties_logos/<%= item.logo %>" class="thumbnail-image">
                </p>
            </a>
            <% } %>
        </div>
        <div class="body">
            <a href="<%- item.path %>">
                <div class="no-anchor listing-pub-title listing-title"><%= item.title %></div>
            </a>
            
            <div class="listing-pub-author listing-author">
                <% 
                const authorRaw = Array.isArray(item.author) ? item.author.join(', ') : (item.author || '');
                const authors = authorRaw.split(',').map(a => a.trim()).filter(a => a.length > 0);
                authors.forEach((author, index) => {
                    const profilePath = profilePathForAuthor(author);
                    %>
                    <% if (profilePath) { %><a href="<%- profilePath %>"><%= author %></a><% } else { %><%= author %><% } %><% 
                    if (index < authors.length - 1) { %>, <% }
                }); 
                %><br> 
            </div>
            
            <div class="metadata-value listing-pub-journal listing-publication">
                <% const venueLabel = item.venue || item.journ; %>
                <% if (venueLabel) { %>
                    <i><%= venueLabel %></i><% if (item.issue) { %>, <b><%= item.issue %></b><% } %><% if (item.page) { %>, <%= item.page %><% } %><% if (item.year) { %> (<%= item.year %>)<% } %><br>
                <% } else if (item.year) { %>
                    <%= item.year %><br>
                <% } %>
            </div>
            
            <div class="listing-pub-links">
                <% if (item.url_source) { %>
                <a href="<%- item.url_source %>">
                    <span style="color:#8250E6;">journal URL <i class="bi bi-box-arrow-up-right"></i></span>
                </a>
                <% } %>
                
                <% if (item.url_preprint) { %>
                <% if (item.url_source) { %> | <% } %>
                <a href="<%- item.url_preprint %>">
                    <span style="color:#8250E6;">preprint URL <i class="bi bi-box-arrow-up-right"></i></span>
                </a>
                <% } %>
                
                <% if (item.doi) { %>
                <% if (item.url_source || item.url_preprint) { %> | <% } %>
                <a href="https://doi.org/<%- item.doi %>" style="text-decoration: none;">
                    <span style="border: 1px solid currentColor; padding: 2px 8px; border-radius: 4px;">DOI <i class="bi bi-box-arrow-up-right"></i></span>
                </a>
                <% } %>
                
                <% if (item.code) { %>
                <% if (item.url_source || item.url_preprint || item.doi) { %> | <% } %>
                <a href="<%- item.code %>" target="_blank" rel="noopener" style="text-decoration: none;">
                    <span style="border: 1px solid currentColor; padding: 2px 8px; border-radius: 4px;">CODE <i class="bi bi-box-arrow-up-right"></i></span>
                </a>
                <% } %>
                
                <% if (item.bibtex) { %>
                <% if (item.url_source || item.url_preprint || item.doi || item.code) { %> | <% } %>
                <% 
                const dirPathBib = item.path.substring(0, item.path.lastIndexOf('/') + 1);
                const bibtexPath = dirPathBib + item.bibtex;
                %>
                <a href="<%- bibtexPath %>" download style="text-decoration: none;">
                    <span style="border: 1px solid currentColor; padding: 2px 8px; border-radius: 4px;">CITE <i class="bi bi-download"></i></span>
                </a>
                <% } %>
                
                <% 
                const listingPdf = item.poster_pdf || item.article_pdf || item.pdf;
                %>
                <% if (listingPdf) { %>
                <% if (item.url_source || item.url_preprint || item.doi || item.code || item.bibtex) { %> | <% } %>
                <% 
                const dirPathPdf = item.path.substring(0, item.path.lastIndexOf('/') + 1);
                const pdfPath = dirPathPdf + listingPdf;
                %>
                <a href="<%- pdfPath %>" download style="text-decoration: none;">
                    <span style="border: 1px solid currentColor; padding: 2px 8px; border-radius: 4px;">PDF <i class="bi bi-download"></i></span>
                </a>
                <% } %>
            </div>
        </div>
    </div>
    
    <% } %>
    </div>

```